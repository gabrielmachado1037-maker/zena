# ── Banco de dados ──────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Produção (PostgreSQL — use a URL do Neon ou Railway):
# DATABASE_URL="postgresql://user:password@host:5432/zena?sslmode=require"

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET="troque-isso-por-uma-string-aleatoria-de-64-chars"

# ── Stripe ──────────────────────────────────────────────────
# Crie sua conta em https://dashboard.stripe.com
# Chaves em: Developers > API Keys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# IDs dos preços em: Developers > Products > [Plano] > Price ID
STRIPE_PRICE_MENSAL="price_..."
STRIPE_PRICE_ANUAL="price_..."

# ── Email (Resend) ───────────────────────────────────────────
# Crie sua conta em https://resend.com
# Chave em: API Keys > Create API Key
RESEND_API_KEY="re_..."

# ── Supabase Storage (fotos de pacientes) ───────────────────
# Crie um projeto em https://supabase.com → Storage → New bucket "fotos" (public)
# Chaves em: Project Settings > API
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Asaas Webhook ─────────────────────────────────────────────
# Token configurado em Integrações → Webhooks no painel Asaas
ASAAS_WEBHOOK_TOKEN="seu_token_aqui"

# ── Web Push / Notificações (VAPID) ─────────────────────────
# Gere o par com:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# (ou: npx web-push generate-vapid-keys)
# SEM estas chaves o push fica silenciosamente desativado (/vapid-public-key = null).
# Use os MESMOS valores em dev e em produção (mudar a pública invalida as assinaturas).
VAPID_PUBLIC_KEY="B..."
VAPID_PRIVATE_KEY="..."

# ── URLs ─────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
# Produção:
# FRONTEND_URL="https://app.zena.app"

# Criptografia de segredos (chaves Asaas). OBRIGATORIA - o backend nao sobe sem ela.
# Gere com: openssl rand -hex 32  (ou: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Deve ser IGUAL em todos os ambientes que compartilham o mesmo banco (local e Render).
ENCRYPTION_KEY=
