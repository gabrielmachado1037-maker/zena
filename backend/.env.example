# ── Banco de dados ──────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Produção (PostgreSQL — use a URL do Neon ou Railway):
# DATABASE_URL="postgresql://user:password@host:5432/zena?sslmode=require"

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET="troque-isso-por-uma-string-aleatoria-de-64-chars"

# ── Stripe ──────────────────────────────────────────────────
# Crie sua conta em https://dashboard.stripe.com
# Chaves em: Developers > API Keys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# IDs dos preços em: Developers > Products > [Plano] > Price ID
STRIPE_PRICE_MENSAL="price_..."
STRIPE_PRICE_ANUAL="price_..."

# ── Email (Resend) ───────────────────────────────────────────
# Crie sua conta em https://resend.com
# Chave em: API Keys > Create API Key
RESEND_API_KEY="re_..."

# ── URLs ─────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
# Produção:
# FRONTEND_URL="https://app.zena.app"
