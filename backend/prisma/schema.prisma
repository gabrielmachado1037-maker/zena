generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Nutricionista {
  id                   String              @id @default(cuid())
  nome                 String
  email                String              @unique
  senha                String
  crn                  String
  tipoProfissional     String              @default("nutricionista")
  foto                 String?
  plano                String              @default("trial")
  planoAtivo           Boolean             @default(true)
  trialEnd             DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  asaasApiKey          String?
  asaasCustomerId      String?
  asaasSubscriptionId  String?
  planoVencimento      DateTime?
  planoSlug            String?
  subscriptionStatus   String              @default("trial")
  subscriptionType     String?
  subscriptionEndsAt   DateTime?
  modulosAtivos        String[]            @default([])
  nomeConsultorio      String?
  logoConsultorio      String?
  enderecoConsultorio  String?
  codigoVinculo        String?             @unique
  // LGPD: registro de consentimento no cadastro.
  aceiteTermosEm       DateTime?
  aceiteTermosVersao   String?
  pacientes            Paciente[]
  horarios             HorarioDisponivel[]
  lembretes            Lembrete[]
  rankingConfig        RankingConfig?
  rankingPontuacoes    RankingPontuacao[]
  feedPosts            FeedPost[]
  pushSubscriptions    PushSubscription[]
  ciclos               Ciclo[]
  feedEncerramentos    FeedEncerramento[]
  cicloCampeoes        CicloCampeao[]
  desafios             Desafio[]
  mensagensNutri       MensagemNutri[]
  mensagensChat        MensagemChat[]
  createdAt            DateTime            @default(now())
}

model TokenRedefinicao {
  id              String   @id @default(cuid())
  nutricionistaId String
  token           String   @unique
  expiresAt       DateTime
  usado           Boolean  @default(false)
  criadoEm        DateTime @default(now())
}

model Paciente {
  id                String             @id @default(cuid())
  nome              String
  email             String?
  telefone          String?
  objetivo          String
  dataInicio        DateTime
  linkUnico         String             @unique @default(cuid())
  ativo             Boolean            @default(true)
  pesoMeta          Float?
  dataNascimento    DateTime?
  sexo              String?
  altura            Float?
  fotoInicial       String?
  fotoPerfilUrl     String?
  nutricionistaId   String
  nutricionista     Nutricionista      @relation(fields: [nutricionistaId], references: [id])
  pontosTotal       Float              @default(0)
  streakAtual       Int                @default(0)
  streakMaximo      Int                @default(0)
  ultimoCheckin     DateTime?
  ligaAtual         String             @default("Bronze")
  ligaNivel         String             @default("III")
  diasInativo       Int                @default(0)
  barraCongelada    Boolean            @default(false)
  // Plano de missões — refeições configuradas pela nutri: [{ key, label }] (3–6).
  // null = 4 refeições padrão (café/almoço/lanche/jantar). Alimentação satura em 4 XP.
  planoRefeicoes    Json?
  // Metas configuradas pela nutri (null = padrão). Água em ml; sono em horas;
  // treinoDias = dias da semana com missão de treino (0=domingo..6=sábado; vazio = todo dia).
  aguaMetaMl        Int?
  sonoMetaHoras     Int?
  treinoDias        Int[]              @default([])
  medicoes          Medicao[]
  consultas         Consulta[]
  cobrancas         Cobranca[]
  planosAlimentares PlanoAlimentar[]
  checkIns          CheckIn[]
  mensagens         MensagemWhatsApp[]
  registrosContato  RegistroContato[]
  anamnese          Anamnese?
  lembretes         Lembrete[]
  planoCobranca     PlanoCobranca?
  fotosEvolucao     FotoEvolucao[]
  registrosFotos    RegistroFotos[]
  rankingPontuacoes        RankingPontuacao[]
  feedPosts                FeedPost[]
  pacienteUser             PacienteUser?
  pushSubscriptionsPaciente PushSubscriptionPaciente[]
  checklistsDiarios     ChecklistDiario[]
  cicloParticipantes    CicloParticipante[]
  relatoriosCiclo       RelatorioCiclo[]
  feedEncerramentos     FeedEncerramento[]
  cicloCampeoes         CicloCampeao[]
  streakMarcos          StreakMarco[]
  pontosLogs            PontosLog[]
  registros             Registro[]
  desafiosProgresso     DesafioProgresso[]
  conquistas            Conquista[]
  mensagensNutri        MensagemNutri[]
  mensagensChat         MensagemChat[]
  // LGPD: marca quando os dados pessoais foram anonimizados a pedido do titular.
  anonimizadoEm         DateTime?
  createdAt                DateTime           @default(now())

  @@index([nutricionistaId])
}

model Anamnese {
  id              String   @id @default(cuid())
  pacienteId      String   @unique
  paciente        Paciente @relation(fields: [pacienteId], references: [id])
  queixaPrincipal String?
  historicoDieta  String?
  restricoes      String?
  medicamentos    String?
  condicoesSaude  String?
  nivelAtividade  String?
  horasSono       Int?
  nivelEstresse   Int?
  refeicoesDia    Int?
  comeCozinha     Boolean?
  comeForaCasa    Int?
  consumoAgua     Float?
  motivacao       String?
  expectativas    String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

model HorarioDisponivel {
  id              String        @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])
  diaSemana       Int
  hora            String
  ativo           Boolean       @default(true)
  duracaoMinutos  Int           @default(60)

  @@unique([nutricionistaId, diaSemana, hora])
}

model Lembrete {
  id              String        @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])
  pacienteId      String
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  tipo            String
  status          String        @default("pendente")
  referencia      String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  @@index([nutricionistaId])
  @@index([status])
}

model CheckIn {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  semana     Int
  ano        Int
  humor      Int
  adesao     Int
  peso       Float?
  foto       String?
  nota       String?
  criadoEm   DateTime @default(now())

  @@unique([pacienteId, semana, ano])
  @@index([pacienteId])
}

model MensagemWhatsApp {
  id           String   @id @default(cuid())
  pacienteId   String
  paciente     Paciente @relation(fields: [pacienteId], references: [id])
  template     String
  textoEnviado String
  criadoEm     DateTime @default(now())

  @@index([pacienteId])
}

model Medicao {
  id          String   @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  data        DateTime
  peso        Float
  gordura     Float?
  musculo     Float?
  cintura     Float?
  quadril     Float?
  braco       Float?
  coxa        Float?
  laudo       String?
  observacoes String?
  createdAt   DateTime @default(now())

  @@index([pacienteId])
}

model PlanoAlimentar {
  id          String   @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  dataCriacao DateTime @default(now())
  cafeManha   String
  lancheManha String?
  almoco      String
  lancheTarde String?
  jantar      String
  ceia        String?
  observacoes String?

  @@index([pacienteId])
}

model Consulta {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  data       DateTime
  status     String   @default("agendada")
  tipo       String   @default("consulta")
  notas      String?
  createdAt  DateTime @default(now())

  @@index([pacienteId])
  @@index([data])
}

model Cobranca {
  id              String    @id @default(cuid())
  pacienteId      String
  paciente        Paciente  @relation(fields: [pacienteId], references: [id])
  valor           Float
  vencimento      DateTime
  status          String    @default("pendente")
  metodo          String?
  pagoEm          DateTime?
  descricao       String?
  asaasChargeId   String?
  pixCopiaECola   String?
  linkPagamento   String?
  createdAt       DateTime  @default(now())

  @@index([pacienteId])
  @@index([status])
  @@index([vencimento])
}

model FotoEvolucao {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  data       DateTime
  tipo       String
  imagem     String
  criadoEm  DateTime @default(now())

  @@index([pacienteId])
}

model RegistroFotos {
  id          String   @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  mes         Int
  ano         Int
  frenteUrl   String?
  perfilUrl   String?
  costasUrl   String?
  observacoes String?
  criadoEm    DateTime @default(now())

  @@unique([pacienteId, mes, ano])
}

model RegistroContato {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  tipo       String   @default("whatsapp")
  resumo     String
  data       DateTime @default(now())
  criadoEm  DateTime @default(now())

  @@index([pacienteId])
}

model PlanoCobranca {
  id              String   @id @default(cuid())
  pacienteId      String   @unique
  paciente        Paciente @relation(fields: [pacienteId], references: [id])
  valor           Float
  periodicidade   String   @default("mensal")
  diaVencimento   Int      @default(10)
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())
}

model DailyQuote {
  id        String   @id @default(cuid())
  date      DateTime @unique
  quote     String
  createdAt DateTime @default(now())
}

// ─── Ranking ──────────────────────────────────────────────────────────────────

// ─── Feed ─────────────────────────────────────────────────────────────────────

model FeedPost {
  id              String           @id @default(cuid())
  tipo            String           @default("CONQUISTA") // legado: META_BATIDA | PESO_ALCANCADO | CONQUISTA
  categoria       String           @default("MOMENTO")   // REFEICAO | TREINO | MOMENTO
  privacidade     String           @default("PUBLICO")   // PUBLICO | APENAS_NUTRI
  pacienteId      String?          // null = post da nutri no Mural (sem paciente-alvo)
  paciente        Paciente?        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  nutricionistaId String
  nutricionista   Nutricionista    @relation(fields: [nutricionistaId], references: [id], onDelete: Cascade)
  mensagem        String
  fotoUrl         String?
  autorAvatarUrl  String?
  curtidas        Int              @default(0)
  privado         Boolean          @default(false)       // legado — usar privacidade
  autorNutri      Boolean          @default(false)
  criadoEm        DateTime         @default(now())
  comentarios     FeedComentario[]

  @@index([nutricionistaId])
  @@index([pacienteId])
  @@index([criadoEm])
}

model FeedComentario {
  id         String   @id @default(cuid())
  feedPostId String
  feedPost   FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  autorId        String
  autorTipo      String   // NUTRICIONISTA | PACIENTE
  autorNome      String
  autorAvatarUrl String?
  texto          String
  createdAt      DateTime @default(now())

  @@index([feedPostId])
  @@index([createdAt])
}

// ─── Ranking ──────────────────────────────────────────────────────────────────

model RankingConfig {
  id              String        @id @default(cuid())
  nutricionistaId String        @unique
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])

  // Pesos (devem somar 100)
  pesoPesoMeta             Int @default(40) // peso da métrica % objetivo de peso
  pesoHabitosConsecutivos  Int @default(30) // peso da métrica hábitos consecutivos
  pesoMetasSemanais        Int @default(30) // peso da métrica metas semanais batidas

  // Thresholds de referência para pontuação máxima
  diasConsecutivosAlvo Int @default(7)  // dias consecutivos = 100pts nessa métrica
  metasSemanaisAlvo    Int @default(4)  // check-ins por mês = 100pts nessa métrica

  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model RankingPontuacao {
  id              String        @id @default(cuid())
  pacienteId      String
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])

  // Período de referência
  periodo String @default("semanal") // "semanal" | "mensal"
  semana  Int?   // ISO week (1–53), preenchido quando periodo = "semanal"
  mes     Int?   // 1–12, preenchido quando periodo = "mensal"
  ano     Int

  // Scores individuais (0–100 cada)
  pctObjetivoPeso         Float @default(0) // progresso em % em direção ao pesoMeta
  diasConsecutivosHabitos Int   @default(0) // dias consecutivos com check-in registrado
  metasSemanaisBatidas    Int   @default(0) // número de semanas com adesão >= 7 no período

  // Score final ponderado (0–100)
  pontuacaoTotal  Float @default(0)
  posicaoRanking  Int?  // posição entre pacientes da nutricionista naquele período

  calculadoEm DateTime @default(now())

  @@unique([pacienteId, periodo, semana, mes, ano])
  @@index([nutricionistaId])
  @@index([nutricionistaId, ano, semana])
  @@index([nutricionistaId, ano, mes])
  @@index([pacienteId])
}

model PacienteUser {
  id                String   @id @default(cuid())
  email             String   @unique
  senha             String
  fotoUrl           String?
  postPublicoPadrao Boolean  @default(true)
  pacienteId        String   @unique
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([email])
}

model PushSubscriptionPaciente {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  criadoEm   DateTime @default(now())

  @@index([pacienteId])
}

model PushSubscription {
  id              String        @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id], onDelete: Cascade)
  endpoint        String        @unique
  p256dh          String
  auth            String
  criadoEm        DateTime      @default(now())

  @@index([nutricionistaId])
}

// ─── Planos SaaS ──────────────────────────────────────────────────────────────

model PlanoSaas {
  id               String   @id @default(cuid())
  nome             String
  slug             String   @unique
  modulos          String[]
  precoMensal      Float
  precoAnualTotal  Float
  precoAnualMensal Float
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
}

// ─── Gamificação: Ciclos ──────────────────────────────────────────────────────

model Ciclo {
  id               String        @id @default(cuid())
  nutricionistaId  String
  nutricionista    Nutricionista @relation(fields: [nutricionistaId], references: [id])
  numero           Int
  titulo           String?
  dataInicio       DateTime
  dataFim          DateTime
  status           String        @default("ativo")
  premioDescricao  String?
  premioTipo       String        @default("reconhecimento")
  relatorioGerado  Boolean       @default(false)
  createdAt        DateTime      @default(now())

  participantes    CicloParticipante[]
  relatorios       RelatorioCiclo[]
  feedEncerramento FeedEncerramento?
  checklists       ChecklistDiario[]
  campeoes         CicloCampeao[]
  streakMarcos     StreakMarco[]

  @@unique([nutricionistaId, numero])
  @@index([nutricionistaId])
}

model CicloParticipante {
  id                     String   @id @default(cuid())
  cicloId                String
  ciclo                  Ciclo    @relation(fields: [cicloId], references: [id])
  pacienteId             String
  paciente               Paciente @relation(fields: [pacienteId], references: [id])
  pontosCiclo            Float    @default(0)
  posicaoAtual           Int      @default(0)
  posicaoAnterior        Int      @default(0)
  diasConsistente        Int      @default(0)
  diasTotal              Int      @default(0)
  percentualConsistencia Float    @default(0)
  melhorCategoria        String?
  streakNoCiclo          Int      @default(0)
  joinedAt               DateTime @default(now())

  @@unique([cicloId, pacienteId])
  @@index([cicloId])
  @@index([pacienteId])
}

model RelatorioCiclo {
  id                   String   @id @default(cuid())
  cicloId              String
  ciclo                Ciclo    @relation(fields: [cicloId], references: [id])
  pacienteId           String
  paciente             Paciente @relation(fields: [pacienteId], references: [id])
  percentualGeral      Float    @default(0)
  percentualHidratacao Float    @default(0)
  percentualRefeicao   Float    @default(0)
  percentualTreino     Float    @default(0)
  melhorSequencia      Int      @default(0)
  pontosTotal          Int      @default(0)
  posicaoFinal         Int      @default(0)
  totalParticipantes   Int      @default(0)
  destaque             String?
  mensagemNutri        String?
  geradoEm             DateTime @default(now())

  @@unique([cicloId, pacienteId])
  @@index([cicloId])
  @@index([pacienteId])
}

model ChecklistDiario {
  id             String   @id @default(cuid())
  pacienteId     String
  paciente       Paciente @relation(fields: [pacienteId], references: [id])
  cicloId        String?
  ciclo          Ciclo?   @relation(fields: [cicloId], references: [id])
  data           DateTime
  refeicoesOk    Boolean  @default(false)
  aguaOk         Boolean  @default(false)
  treinoOk       Boolean  @default(false)
  pontosRefeicao Int      @default(0)
  pontosAgua     Int      @default(0)
  pontosTreino   Int      @default(0)
  pontosTotalDia Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([pacienteId, data])
  @@index([pacienteId])
  @@index([cicloId])
}

model FeedEncerramento {
  id              String        @id @default(cuid())
  cicloId         String        @unique
  ciclo           Ciclo         @relation(fields: [cicloId], references: [id])
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])
  vencedorId      String?
  vencedor        Paciente?     @relation(fields: [vencedorId], references: [id])
  top3            Json?
  mensagem        String?
  publicadoEm     DateTime      @default(now())

  @@index([nutricionistaId])
}

// ─── Campeões de ciclo ────────────────────────────────────────────────────────

model CicloCampeao {
  id                     String        @id @default(cuid())
  cicloId                String
  ciclo                  Ciclo         @relation(fields: [cicloId], references: [id])
  pacienteId             String
  paciente               Paciente      @relation(fields: [pacienteId], references: [id])
  nutricionistaId        String
  nutricionista          Nutricionista @relation(fields: [nutricionistaId], references: [id])
  posicao                Int
  pontosFinais           Float
  percentualConsistencia Float?
  streakMaximo           Int           @default(0)
  fotoUrl                String?
  nomePaciente           String
  escudoAtivo            Boolean       @default(false)
  escudoExpiresEm        DateTime?
  cicloNumero            Int           @default(0)
  cicloTitulo            String?
  cicloDataFim           DateTime?
  createdAt              DateTime      @default(now())

  @@index([nutricionistaId, createdAt(sort: Desc)])
  @@index([cicloId])
}

model StreakMarco {
  id          String   @id @default(cuid())
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  cicloId     String
  ciclo       Ciclo    @relation(fields: [cicloId], references: [id])
  marco       Int
  pontosBonus Float
  concedidoEm DateTime @default(now())

  @@unique([pacienteId, cicloId, marco])
  @@index([pacienteId])
}

model PontosLog {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  tipo       String
  pontos     Float
  data       DateTime @db.Date
  createdAt  DateTime @default(now())

  @@index([pacienteId, tipo, data])
}

// ─── Sistema de Ligas (Nexvel) ─────────────────────────────────────────────

model Registro {
  id             String   @id @default(cuid())
  pacienteId     String
  paciente       Paciente @relation(fields: [pacienteId], references: [id])
  data           DateTime @db.Date

  alimentacaoOk  Boolean  @default(false)
  treinoOk       Boolean  @default(false)
  aguaOk         Boolean  @default(false)
  sonoOk         Boolean  @default(false)

  // Detalhe por refeição (alimenta insights/relatório da nutri). Nullable = "sem dado"
  // p/ registros antigos. cafeOk etc. = derivados de *Status ("seguiu"), mantidos p/ as
  // agregações booleanas legadas. alimentacaoOk = derivado (xpAlimentacao >= 3).
  cafeOk         Boolean?
  almocoOk       Boolean?
  lancheOk       Boolean?
  jantarOk       Boolean?

  // Estado por refeição (3 estados): "seguiu" | "adaptou" | "pulou". Base da análise
  // de comportamento alimentar da nutri e da pontuação (seguiu 1 / adaptou 0.5 / pulou 0).
  cafeStatus     String?
  almocoStatus   String?
  lancheStatus   String?
  jantarStatus   String?
  // Notas por refeição: { cafe: { nota?, motivo? }, ... } (o que mudou / por que pulou)
  refeicoesNotas Json?
  // Estado por refeição para N refeições (3–6): { key: "seguiu|adaptou|comeu_mal|pulou" }.
  // Fonte da verdade da alimentação quando o plano tem != 4 refeições; para o padrão de 4,
  // as colunas cafeStatus…jantarStatus continuam espelhadas (retrocompat com agregações).
  refeicoesStatus Json?

  // Água como progresso (ml) em vez de booleano. aguaOk = derivado (aguaMl >= aguaMetaMl).
  aguaMl         Int?
  aguaMetaMl     Int?

  // Treino em 3 estados: "conforme" (3 XP) | "parcial" (1) | "nao" (0). treinoOk = derivado
  // (status != "nao"). Motivo preenchido quando não conseguiu treinar.
  treinoStatus   String?
  treinoMotivo   String?
  // Sono por faixa de horas: "menos5" (0) | "5a7" (1) | "7a9" (2) | "mais9" (2). sonoOk = XP > 0.
  sonoFaixa      String?
  // Horas dormidas informadas pelo paciente. Pontua por tolerância vs Paciente.sonoMetaHoras
  // (±1h = 2 XP · até 2h = 1 · além = 0). Registros antigos sem este campo usam sonoFaixa.
  sonoHoras      Float?

  // O dia foi fechado (finalizado) — só então credita registro_diario + bônus + streak.
  // Antes disso o registro é editável (autosave) e não pontua na liga.
  finalizado     Boolean  @default(false)

  tipoRegistro   String   @default("normal") // normal | excecao | ajuste_necessario

  fotoUrl        String?
  descricao      String?
  humor          String?  // otimo | bom | neutro | dificil | pessimo
  tags           String[] @default([])

  pontosGanhos   Float    @default(0)
  pontosDetalhes Json?

  pediuAjuste    Boolean  @default(false)
  motivoAjuste   String?
  ajusteLido     Boolean  @default(false)
  revisado       Boolean  @default(false)

  createdAt      DateTime @default(now())

  @@unique([pacienteId, data])
  @@index([pacienteId])
  @@index([pediuAjuste])
}

model Desafio {
  id              String             @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista      @relation(fields: [nutricionistaId], references: [id])
  titulo          String
  descricao       String?
  tipo            String             @default("custom") // hidratacao | alimentacao | treino | sono | custom
  metaValor       Float?
  metaUnidade     String?
  duracaoDias     Int                @default(7)
  dataInicio      DateTime?          @db.Date
  dataFim         DateTime?          @db.Date
  icone           String             @default("🎯")
  pontosBonus     Int                @default(0)
  status          String             @default("ativo")
  createdAt       DateTime           @default(now())

  progresso       DesafioProgresso[]

  @@index([nutricionistaId])
}

model DesafioProgresso {
  id         String   @id @default(cuid())
  desafioId  String
  desafio    Desafio  @relation(fields: [desafioId], references: [id])
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  progresso  Float    @default(0) // percentual 0-100 (derivado de diasCumpridos/duração)
  diasCumpridos Int    @default(0) // dias de aderência cumpridos na janela do desafio
  diasManuais String[] @default([]) // datas (yyyy-mm-dd) marcadas à mão em desafios custom
  concluido  Boolean  @default(false)
  // Encerrado (janela terminou): concluído=true venceu; concluído=false = não atingiu o mínimo.
  // Ativo = concluido=false E encerradoEm=null.
  encerradoEm DateTime?
  createdAt  DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  @@unique([desafioId, pacienteId])
  @@index([pacienteId])
}

model Conquista {
  id           String   @id @default(cuid())
  pacienteId   String
  paciente     Paciente @relation(fields: [pacienteId], references: [id])
  tipo         String   // sequencia_7 | sequencia_30 | subiu_liga | desafio_concluido | checkpoint_foto | lendario
  titulo       String
  descricao    String?
  icone        String?
  pontosBonus  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([pacienteId])
}

model MensagemNutri {
  id              String        @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])
  pacienteId      String
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  tipo            String        @default("motivacional") // motivacional | ajuste | parabenizacao | alerta
  conteudo        String
  lida            Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([nutricionistaId])
  @@index([pacienteId])
}

// Chat bidirecional nutri <-> paciente (tela de Mensagens).
model MensagemChat {
  id              String        @id @default(cuid())
  nutricionistaId String
  nutricionista   Nutricionista @relation(fields: [nutricionistaId], references: [id])
  pacienteId      String
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  autor           String // "paciente" | "nutri"
  conteudo        String
  anexoUrl        String?
  lida            Boolean       @default(false)
  criadoEm        DateTime      @default(now())

  @@index([nutricionistaId])
  @@index([pacienteId])
}
